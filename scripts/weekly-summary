#!/bin/bash
# weekly-summary - Pull stats from ejfox.com APIs and append to weekly note
# Usage: weekly-summary [-n|--dry-run] [-w|--week YYYY-WW]
#
# By default, appends stats to the current week's note.
# Use --dry-run to preview without writing.

BASE_URL="https://ejfox.com/api"
VAULT_DIR="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/ejfox"
DRY_RUN=false
WEEK=""

# Parse args
while [[ $# -gt 0 ]]; do
  case $1 in
    --dry-run|-n) DRY_RUN=true; shift ;;
    --week|-w) WEEK="$2"; shift 2 ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

# Default to current week
if [[ -z "$WEEK" ]]; then
  WEEK=$(date +"%Y-%V")
fi

echo "📊 Fetching stats for week $WEEK..."
echo ""

# Fetch all APIs (with timeouts)
RESCUETIME=$(curl -s --max-time 10 "$BASE_URL/rescuetime" 2>/dev/null || echo '{}')
GITHUB=$(curl -s --max-time 10 "$BASE_URL/github" 2>/dev/null || echo '{}')
LASTFM=$(curl -s --max-time 10 "$BASE_URL/lastfm" 2>/dev/null || echo '{}')
LETTERBOXD=$(curl -s --max-time 10 "$BASE_URL/letterboxd" 2>/dev/null || echo '{}')
GOODREADS=$(curl -s --max-time 10 "$BASE_URL/goodreads" 2>/dev/null || echo '{}')
CHESS=$(curl -s --max-time 10 "$BASE_URL/chess" 2>/dev/null || echo '{}')
HEALTH=$(curl -s --max-time 10 "$BASE_URL/apple-health" 2>/dev/null || echo '{}')

# Parse RescueTime - .week.summary has total, productive, .week.categories and .week.activities
RT_TOTAL=$(echo "$RESCUETIME" | jq -r '.week.summary.total.formatted // "0h 0m"' 2>/dev/null || echo "0h 0m")
RT_PRODUCTIVE=$(echo "$RESCUETIME" | jq -r '.week.summary.productive.percentage // 0' 2>/dev/null || echo "0")
RT_TOP_ACTIVITIES=$(echo "$RESCUETIME" | jq -r '(.week.activities // [])[:5] | map("- \(.name): \(.time.formatted // "?")") | join("\n")' 2>/dev/null || echo "_No data_")
RT_TOP_CATEGORIES=$(echo "$RESCUETIME" | jq -r '(.week.categories // [])[:5] | map("- \(.name): \(.time.formatted // "?")") | join("\n")' 2>/dev/null || echo "_No data_")

# Parse GitHub - .detail.commits[] has .repository.name, .message, .type
GH_TOTAL_COMMITS=$(echo "$GITHUB" | jq -r '(.detail.commits // []) | length' 2>/dev/null || echo "0")
GH_RECENT=$(echo "$GITHUB" | jq -r '(.detail.commits // [])[:8] | map("- [\(.repository.name)]: \(.message | split("\n")[0] | .[0:60])") | join("\n")' 2>/dev/null || echo "_No data_")
GH_TYPES=$(echo "$GITHUB" | jq -r '[(.detail.commits // [])[].type] | group_by(.) | map({type: .[0], count: length}) | sort_by(-.count) | .[:5] | map("- \(.type): \(.count)") | join("\n")' 2>/dev/null || echo "_No data_")

# Parse Last.fm - .topArtists.artists[], .recentTracks.tracks[]
LFM_ARTISTS=$(echo "$LASTFM" | jq -r '(.topArtists.artists // [])[:5] | map("- \(.name) (\(.playcount) plays)") | join("\n")' 2>/dev/null || echo "_No data_")
LFM_RECENT=$(echo "$LASTFM" | jq -r '(.recentTracks.tracks // [])[:3] | map("- \(.name) by \(.artist.name)") | join("\n")' 2>/dev/null || echo "_No data_")

# Parse Letterboxd - .films[], .stats
LB_RECENT=$(echo "$LETTERBOXD" | jq -r '(.films // [])[:5] | map("- \(.title)\(if .rating and .rating != "" then " (\(.rating))" else "" end)") | join("\n")' 2>/dev/null || echo "_No films logged_")
LB_THIS_WEEK=$(echo "$LETTERBOXD" | jq -r '.stats.thisWeek // 0' 2>/dev/null || echo "0")
LB_THIS_MONTH=$(echo "$LETTERBOXD" | jq -r '.stats.thisMonth // 0' 2>/dev/null || echo "0")

# Parse Goodreads - .currentlyReading[], .recentlyRead[]
GR_READING=$(echo "$GOODREADS" | jq -r '(.currentlyReading // [])[:3] | map("- *\(.title)* by \(.author)") | join("\n")' 2>/dev/null || echo "_Nothing tracked_")
GR_RECENT=$(echo "$GOODREADS" | jq -r '(.recentlyRead // [])[:3] | map("- *\(.title)* by \(.author)\(if .rating then " (\(.rating)★)" else "" end)") | join("\n")' 2>/dev/null || echo "_Nothing tracked_")

# Parse Chess - .recentGames[], .currentRating.bullet/blitz
CHESS_RECENT=$(echo "$CHESS" | jq -r '(.recentGames // [])[:5] | map("- vs \(.opponent) (\(.timeControl)): \(.result)") | join("\n")' 2>/dev/null || echo "_No recent games_")
CHESS_BULLET=$(echo "$CHESS" | jq -r '.currentRating.bullet // "N/A"' 2>/dev/null || echo "N/A")
CHESS_BLITZ=$(echo "$CHESS" | jq -r '.currentRating.blitz // "N/A"' 2>/dev/null || echo "N/A")

# Parse Health - .thisWeek.steps, etc (round to integers)
HEALTH_STEPS=$(echo "$HEALTH" | jq -r '(.thisWeek.steps // 0) | floor' 2>/dev/null || echo "0")
HEALTH_EXERCISE=$(echo "$HEALTH" | jq -r '(.thisWeek.exerciseMinutes // 0) | floor' 2>/dev/null || echo "0")
HEALTH_FLIGHTS=$(echo "$HEALTH" | jq -r '(.thisMonth.flightsClimbed // 0) | floor' 2>/dev/null || echo "0")

# Build output
OUTPUT="## Weekly Stats Summary

> Auto-generated by \`weekly-summary\` on $(date '+%Y-%m-%d %H:%M')

---

### 💻 Screen Time (RescueTime)
**${RT_TOTAL} total** | ${RT_PRODUCTIVE}% productive

**Top Activities:**
${RT_TOP_ACTIVITIES}

**Top Categories:**
${RT_TOP_CATEGORIES}

---

### 🔨 Code (GitHub)
**${GH_TOTAL_COMMITS} commits** in the last 30 days

**Commit Types:**
${GH_TYPES}

**Recent Commits:**
${GH_RECENT}

---

### 🎵 Music (Last.fm)
**Top Artists:**
${LFM_ARTISTS}

**Recently Played:**
${LFM_RECENT}

---

### 📚 Reading (Goodreads)
**Currently Reading:**
${GR_READING}

**Recently Finished:**
${GR_RECENT}

---

### 🎬 Films (Letterboxd)
**This Week:** ${LB_THIS_WEEK} films | **This Month:** ${LB_THIS_MONTH}

**Recent:**
${LB_RECENT}

---

### ♟️ Chess
**Ratings:** Bullet ${CHESS_BULLET} | Blitz ${CHESS_BLITZ}

**Recent Games:**
${CHESS_RECENT}

---

### 🏃 Health
- Steps: ${HEALTH_STEPS}
- Exercise: ${HEALTH_EXERCISE} min
- Flights climbed: ${HEALTH_FLIGHTS}

---
"

# Output
echo "$OUTPUT"

# Write to file unless --dry-run
if ! $DRY_RUN; then
  WEEK_FILE="$VAULT_DIR/week-notes/${WEEK}.md"
  if [[ -f "$WEEK_FILE" ]]; then
    echo ""
    echo "---"
    echo "📝 Appending to $WEEK_FILE..."
    echo "" >> "$WEEK_FILE"
    echo "$OUTPUT" >> "$WEEK_FILE"
    echo "✅ Done! Open in Obsidian to review."
  else
    echo "⚠️  Week file doesn't exist: $WEEK_FILE"
    echo "   Create it first, then run again."
  fi
else
  echo ""
  echo "---"
  echo "🔍 Dry run - nothing written. Remove --dry-run to append to week note."
fi
