# =============================================================================
# DOTFILES GITIGNORE - SECURITY FIRST
# =============================================================================
# Rule: If a file COULD contain secrets, it should NOT be in this repo.
# Instead, symlink from ~/.secrets/ or use .example templates.
# =============================================================================

# -----------------------------------------------------------------------------
# CREDENTIAL FILES - NEVER COMMIT THESE
# -----------------------------------------------------------------------------
# Network/API credentials
.netrc
.authinfo
.authinfo.gpg

# SSH keys and configs with secrets
*_rsa
*_dsa
*_ed25519
*_ecdsa
*.pem
*.key
*.p12
*.pfx
id_*
known_hosts

# Environment files (use .env.example templates instead)
.env
.env.*
!.env.example
!.env.template

# Cloud provider credentials
.aws/credentials
.aws/config
.gcloud/
.azure/
.oci/
credentials.json
*credentials*.json
*-credentials.json

# API tokens and secrets
*.secret
*.secrets
*secret*
*token*
!*.secrets.example

# Claude/AI tool secrets
claude.json
.claude-secrets

# -----------------------------------------------------------------------------
# APPLICATION CONFIGS THAT CONTAIN CREDENTIALS
# -----------------------------------------------------------------------------
# Crypto wallets - NEVER EVER
.electrum/
.bitcoin/
.ethereum/
.gnupg/private-keys*
.gnupg/secring*

# Docker (may contain registry auth)
.docker/config.json
.docker/credentials

# Package managers (may contain registry tokens)
.npmrc
.yarnrc
.yarnrc.yml
.pip/pip.conf
.pypirc
.gem/credentials
.cargo/credentials
.cargo/credentials.toml

# HTTP clients (may contain saved auth)
.httpie/
.insomnia/
.postman/
.hurl/

# Database clients
.pgpass
.my.cnf
.psqlrc

# Cloud CLIs
.netlify/
.vercel/
.railway/
.fly/
.heroku/

# Chat/communication
.irssi/config  # May contain server passwords
.weechat/sec.conf

# Git credentials (managed by credential helper, not dotfiles)
.git-credentials

# -----------------------------------------------------------------------------
# SAFE TO IGNORE - NOT SECURITY RELATED
# -----------------------------------------------------------------------------
# Local overrides (personal, not shareable)
.tmux.conf.local
*.local

# Build artifacts
node_modules/
dist/
build/
.next/
.nuxt/

# macOS
Library/
*.app/
.DS_Store
.Trash/

# Editor temps
*.swp
*.swo
*~
.*.tmp
*.bak
*.backup

# Logs
*.log
logs/

# -----------------------------------------------------------------------------
# AUTO-FLIPPED BY appearance-watcher (live state, not source of truth)
# -----------------------------------------------------------------------------
# These are rewritten on every macOS dark/light flip — live state, untracked.
# The tracked sources of truth live alongside them:
#   - yazi:    .config/yazi/vulpes-reddishnovember-{dark,light}.toml
#   - lazygit: .config/lazygit/vulpes-reddishnovember-{dark,light}.yml
#   - btop:    .config/btop/btop-{dark,light}.conf  (edit BOTH to change a setting)
#   - tmux:    vulpes-reddish2-{dark,light}-tmux.tmux.conf (via 'current' symlink)
# skip-worktree hack retired 2026-07-15 — no tracked file flips anymore.
.config/yazi/theme.toml
.config/lazygit/config.yml
.config/btop/btop.conf
vulpes-reddish2-current-tmux.tmux.conf

# Per-machine Ghostty overrides (shaders on/off depending on GPU)
.config/ghostty/config.local

# Karabiner local backups (machine-specific, never sync)
.config/karabiner/automatic_backups/
.config/karabiner/karabiner.json.pre-*
.config/fzf/current.sh
