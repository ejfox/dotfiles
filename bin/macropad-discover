#!/usr/bin/env python3
"""Macropad key discovery tool.

Press each key on your macropad in grid order (row by row, left to right,
top to bottom). The tool detects the macOS virtual keycode for each press
and builds a map of your physical layout.

After discovery, outputs:
  1. A visual grid of keycodes
  2. A JSON mapping file at ~/.config/macropad/layout.json
  3. Karabiner-ready key_code names

Requires: pip install pyobjc-framework-Quartz
Permissions: System Settings > Privacy & Security > Input Monitoring
"""

import json
import os
import signal
import sys
import threading
import time

import Quartz
from Quartz import (
    CGEventGetIntegerValueField,
    CGEventTapCreate,
    CGEventTapEnable,
    CFMachPortCreateRunLoopSource,
    CFRunLoopGetCurrent,
    CFRunLoopAddSource,
    CFRunLoopRun,
    CFRunLoopStop,
    kCGSessionEventTap,
    kCGHeadInsertEventTap,
    kCGEventTapOptionListenOnly,
    kCGEventKeyDown,
    kCFAllocatorDefault,
    kCFRunLoopCommonModes,
)

kCGKeyboardEventKeycode = 9

# macOS virtual keycode → Karabiner key_code name
KEYCODE_TO_KARABINER = {
    0: "a", 1: "s", 2: "d", 3: "f", 4: "h", 5: "g", 6: "z", 7: "x",
    8: "c", 9: "v", 11: "b", 12: "q", 13: "w", 14: "e", 15: "r",
    16: "y", 17: "t", 18: "1", 19: "2", 20: "3", 21: "4", 22: "6",
    23: "5", 24: "equal_sign", 25: "9", 26: "7", 27: "hyphen", 28: "8",
    29: "0", 30: "close_bracket", 31: "o", 32: "u", 33: "open_bracket",
    34: "i", 35: "p", 36: "return_or_enter", 37: "l", 38: "j",
    39: "quote", 40: "k", 41: "semicolon", 42: "backslash", 43: "comma",
    44: "slash", 45: "n", 46: "m", 47: "period", 48: "tab", 49: "spacebar",
    50: "grave_accent_and_tilde", 51: "delete_or_backspace", 53: "escape",
    # Modifiers
    54: "right_command", 55: "left_command", 56: "left_shift",
    57: "caps_lock", 58: "left_option", 59: "left_control",
    60: "right_shift", 61: "right_option", 62: "right_control",
    63: "fn",
    # Arrows
    123: "left_arrow", 124: "right_arrow", 125: "down_arrow", 126: "up_arrow",
    # Function keys
    122: "f1", 120: "f2", 99: "f3", 118: "f4", 96: "f5", 97: "f6",
    98: "f7", 100: "f8", 101: "f9", 109: "f10", 103: "f11", 111: "f12",
    105: "f13", 107: "f14", 113: "f15",
    # Navigation
    114: "insert", 115: "home", 116: "page_up", 117: "delete_forward",
    119: "end", 121: "page_down",
    # Keypad
    65: "keypad_period", 67: "keypad_asterisk", 69: "keypad_plus",
    71: "keypad_num_lock", 75: "keypad_slash", 76: "keypad_enter",
    78: "keypad_hyphen", 81: "keypad_equal_sign",
    82: "keypad_0", 83: "keypad_1", 84: "keypad_2", 85: "keypad_3",
    86: "keypad_4", 87: "keypad_5", 88: "keypad_6", 89: "keypad_7",
    91: "keypad_8", 92: "keypad_9",
}

# Friendly names for display
KEYCODE_FRIENDLY = {
    82: "KP 0", 83: "KP 1", 84: "KP 2", 85: "KP 3", 86: "KP 4",
    87: "KP 5", 88: "KP 6", 89: "KP 7", 91: "KP 8", 92: "KP 9",
    65: "KP .", 67: "KP *", 69: "KP +", 71: "NumLk", 75: "KP /",
    76: "KP Ent", 78: "KP -", 81: "KP =",
    36: "Return", 48: "Tab", 49: "Space", 51: "Bksp", 53: "Esc",
    122: "F1", 120: "F2", 99: "F3", 118: "F4", 96: "F5", 97: "F6",
    98: "F7", 100: "F8", 101: "F9", 109: "F10", 103: "F11", 111: "F12",
    123: "Left", 124: "Right", 125: "Down", 126: "Up",
}


class MacropadDiscovery:
    def __init__(self):
        self.keys = []           # list of discovered keycodes in press order
        self.waiting = True      # currently waiting for a keypress
        self.done = False        # user finished discovery
        self.last_keycode = None
        self.run_loop = None
        self.lock = threading.Lock()

    def key_name(self, kc):
        if kc in KEYCODE_FRIENDLY:
            return KEYCODE_FRIENDLY[kc]
        if kc in KEYCODE_TO_KARABINER:
            return KEYCODE_TO_KARABINER[kc]
        return f"?{kc}"

    def karabiner_name(self, kc):
        return KEYCODE_TO_KARABINER.get(kc, f"unknown_{kc}")

    def on_key(self, keycode):
        with self.lock:
            if not self.waiting or self.done:
                return
            self.last_keycode = keycode
            self.waiting = False

    def print_grid(self, keys, cols):
        """Print discovered keys as a grid."""
        rows_data = []
        for i in range(0, len(keys), cols):
            rows_data.append(keys[i:i+cols])

        # Calculate column width
        w = 8
        border = "+" + (("-" * w + "+") * cols)

        print()
        print(border)
        for row in rows_data:
            cells = []
            for kc in row:
                name = self.key_name(kc)
                cells.append(f" {name:^{w-2}} ")
            # Pad incomplete row
            while len(cells) < cols:
                cells.append(" " * w)
            print("|" + "|".join(cells) + "|")
            print(border)

    def run_discovery(self):
        print()
        print("=" * 60)
        print("  MACROPAD KEY DISCOVERY")
        print("=" * 60)
        print()
        print("We'll map your macropad's physical layout to keycodes.")
        print()
        print("First: how many columns does your macropad have?")
        print("(Standard numpad = 4 columns)")
        print()

        try:
            cols = int(input("Columns [4]: ").strip() or "4")
        except (ValueError, EOFError):
            cols = 4

        print()
        print(f"OK, {cols} columns. Now press each key in order:")
        print(f"  Row 1: left to right ({cols} keys)")
        print(f"  Row 2: left to right ({cols} keys)")
        print(f"  ...and so on.")
        print()
        print("Commands:")
        print("  Press a macropad key → records it")
        print("  Type 'w' + Enter     → mark wide key (2 cols)")
        print("  Type 'u' + Enter     → undo last key")
        print("  Type 'd' + Enter     → done, finish discovery")
        print("  Ctrl+C               → quit without saving")
        print()
        print("-" * 60)

        key_num = 0
        wide_keys = set()  # indices of keys that span 2 columns

        while not self.done:
            row = (key_num // cols) + 1
            col = (key_num % cols) + 1
            prompt = f"  Key #{key_num+1:2d} (row {row}, col {col}): waiting..."
            sys.stdout.write(f"\r{prompt}")
            sys.stdout.flush()

            self.waiting = True
            self.last_keycode = None

            # Poll for keypress or stdin command
            while self.waiting and not self.done:
                # Check stdin (non-blocking-ish via short timeout)
                import select
                if select.select([sys.stdin], [], [], 0.1)[0]:
                    cmd = sys.stdin.readline().strip().lower()
                    if cmd == 'd':
                        self.done = True
                        break
                    elif cmd == 'u':
                        if self.keys:
                            removed = self.keys.pop()
                            if key_num - 1 in wide_keys:
                                wide_keys.discard(key_num - 1)
                                key_num -= 2  # wide key took 2 col slots
                            else:
                                key_num -= 1
                            sys.stdout.write(f"\r  Undid key #{key_num+1} ({self.key_name(removed)})          \n")
                        break
                    elif cmd == 'w':
                        # Next key press will be marked as wide (2 cols)
                        sys.stdout.write(f"\r  Next key will be marked as WIDE (spans 2 cols)          \n")
                        self.waiting = True
                        wide_next = True
                        # Wait for the actual keypress
                        while self.waiting and not self.done:
                            if select.select([sys.stdin], [], [], 0.1)[0]:
                                sys.stdin.readline()  # consume
                            time.sleep(0.05)
                        if self.last_keycode is not None and not self.done:
                            kc = self.last_keycode
                            self.keys.append(kc)
                            wide_keys.add(len(self.keys) - 1)
                            name = self.key_name(kc)
                            karab = self.karabiner_name(kc)
                            sys.stdout.write(
                                f"\r  Key #{key_num+1:2d} (row {row}, col {col}-{col+1}): "
                                f"keycode={kc} → {name} (karabiner: {karab}) [WIDE]          \n"
                            )
                            key_num += 2  # wide key takes 2 column slots
                        break
                time.sleep(0.05)

            if self.done:
                break

            if self.last_keycode is not None:
                kc = self.last_keycode
                self.keys.append(kc)
                name = self.key_name(kc)
                karab = self.karabiner_name(kc)
                sys.stdout.write(
                    f"\r  Key #{key_num+1:2d} (row {row}, col {col}): "
                    f"keycode={kc} → {name} (karabiner: {karab})          \n"
                )
                key_num += 1

        # Show results
        if not self.keys:
            print("\nNo keys recorded.")
            return

        print()
        print("=" * 60)
        print("  DISCOVERY COMPLETE")
        print("=" * 60)
        print(f"\n  {len(self.keys)} keys recorded in {(key_num + cols - 1) // cols} rows x {cols} cols")

        # Build grid display using key_num (accounts for wide keys)
        grid_codes = []
        ki = 0
        for idx, kc in enumerate(self.keys):
            grid_codes.append(kc)
            if idx in wide_keys:
                grid_codes.append(kc)  # duplicate for the extra column
        self.print_grid(grid_codes, cols)

        # Build layout JSON
        layout = {
            "device": {"vendor_id": 8352, "product_id": 16941, "name": "ps2avrGB macropad"},
            "columns": cols,
            "keys": [],
        }
        col_pos = 0
        row_pos = 0
        for idx, kc in enumerate(self.keys):
            is_wide = idx in wide_keys
            entry = {
                "index": idx,
                "row": row_pos,
                "col": col_pos,
                "keycode": kc,
                "karabiner": self.karabiner_name(kc),
                "name": self.key_name(kc),
            }
            if is_wide:
                entry["width"] = 2
            layout["keys"].append(entry)
            col_pos += 2 if is_wide else 1
            if col_pos >= cols:
                col_pos = 0
                row_pos += 1

        # Save
        out_dir = os.path.expanduser("~/.config/macropad")
        os.makedirs(out_dir, exist_ok=True)
        out_path = os.path.join(out_dir, "layout.json")
        with open(out_path, "w") as f:
            json.dump(layout, f, indent=2)
        print(f"\n  Saved to: {out_path}")

        # Print Karabiner snippet
        print("\n  Karabiner key_code names for your macropad:")
        print("  " + "-" * 40)
        for entry in layout["keys"]:
            w = " [wide]" if entry.get("width", 1) > 1 else ""
            print(f"    row {entry['row']}, col {entry['col']}: \"{entry['karabiner']}\"{w}")

        print()
        print("  Next step: update karabiner.json with these key_code values.")
        print("  Run `hue list` to get room names, then map keys → rooms.")


def callback(proxy, event_type, event, refcon):
    if event_type == Quartz.kCGEventTapDisabledByTimeout:
        CGEventTapEnable(proxy, True)
        return event
    if event_type != kCGEventKeyDown:
        return event
    keycode = CGEventGetIntegerValueField(event, kCGKeyboardEventKeycode)
    if refcon is not None:
        refcon.on_key(keycode)
    return event


def main():
    discovery = MacropadDiscovery()

    event_mask = 1 << kCGEventKeyDown
    event_tap = CGEventTapCreate(
        kCGSessionEventTap,
        kCGHeadInsertEventTap,
        kCGEventTapOptionListenOnly,
        event_mask,
        callback,
        discovery,
    )

    if event_tap is None:
        print("ERROR: Could not create event tap.")
        print()
        print("Grant permissions in System Settings:")
        print("  Privacy & Security > Input Monitoring → enable your terminal")
        print("  Privacy & Security > Accessibility → enable your terminal")
        sys.exit(1)

    run_loop_source = CFMachPortCreateRunLoopSource(kCFAllocatorDefault, event_tap, 0)
    run_loop = CFRunLoopGetCurrent()
    CFRunLoopAddSource(run_loop, run_loop_source, kCFRunLoopCommonModes)
    CGEventTapEnable(event_tap, True)
    discovery.run_loop = run_loop

    # Run the CFRunLoop in a background thread so we can use stdin in the main thread
    def run_loop_thread():
        CFRunLoopRun()

    t = threading.Thread(target=run_loop_thread, daemon=True)
    t.start()

    def signal_handler(sig, frame):
        print("\n\nAborted.")
        CFRunLoopStop(run_loop)
        sys.exit(0)

    signal.signal(signal.SIGINT, signal_handler)

    try:
        discovery.run_discovery()
    finally:
        CFRunLoopStop(run_loop)


if __name__ == "__main__":
    main()
