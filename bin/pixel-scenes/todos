#!/usr/bin/env bash
# Today's task list from Things. Caches things-cli output for 5 min to avoid
# repeated Touch ID / TCC prompts when multiple scenes fire close together.
set -u
: "${PIXEL_BASE:?must be invoked via pixel wrapper}"
command -v things-cli >/dev/null || exit 0

CACHE="/tmp/things-today.cache"
MAX_AGE=300

needs_refresh() {
  [ ! -s "$CACHE" ] && return 0
  AGE=$(( $(date +%s) - $(stat -f %m "$CACHE" 2>/dev/null || echo 0) ))
  [ "$AGE" -gt "$MAX_AGE" ]
}

if needs_refresh; then
  things-cli today 2>/dev/null > "$CACHE.tmp" && mv "$CACHE.tmp" "$CACHE"
fi
[ -s "$CACHE" ] || exit 0

# Get up to 5 tasks, prefer 🌞-foundation tasks first
mapfile -t SUN_TASKS < <(grep "🌞" "$CACHE" | head -5)
mapfile -t OTHER_TASKS < <(grep -v "🌞" "$CACHE" | grep -v "^$" | head -5)

# Combine, foundation first, max 5 total
ALL=("${SUN_TASKS[@]}" "${OTHER_TASKS[@]}")
COUNT=${#ALL[@]}
[ "$COUNT" -eq 0 ] && exit 0
[ "$COUNT" -gt 5 ] && COUNT=5

enc() { echo "$1" | sed 's/&/%26/g; s/?/%3F/g; s/+/%2B/g; s/ /%20/g; s/=/%3D/g; s/#/%23/g; s/'\''/%27/g; s/:/%3A/g; s/,/%2C/g; s/"/%22/g'; }

# Strip things-cli formatting: leading "- ", 🌞 emoji, trailing " (date | project)"
clean_task() {
  echo "$1" \
    | sed 's/^-[[:space:]]*//' \
    | sed 's/🌞//g' \
    | sed 's/[[:space:]]*([^)]*)[[:space:]]*$//' \
    | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

# Word-wrap text to fit ~26 chars/line at size 2
wrap_text() {
  local s="$1" max=26
  while [ -n "$s" ]; do
    if [ ${#s} -le "$max" ]; then echo "$s"; break; fi
    local chunk="${s:0:$max}" cut_at
    cut_at=$(echo "$chunk" | awk '{for(i=length;i>0;i--) if(substr($0,i,1)==" "){print i-1; exit}}')
    [ -z "$cut_at" ] || [ "$cut_at" -eq 0 ] && cut_at=$max
    echo "${s:0:$cut_at}"
    s="${s:$cut_at}"; s="${s# }"
  done
}

px "clear"

# Just the tasks. Size 2 text, line height 22, task gap 8. Stop when out of room.
Y=15
MAX_Y=230
for task in "${ALL[@]:0:$COUNT}"; do
  CLEAN=$(clean_task "$task")
  [ -z "$CLEAN" ] && continue

  # Wrap to up to 2 lines per task
  LINES_DRAWN=0
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    [ "$Y" -gt "$MAX_Y" ] && break 2
    px "text?msg=$(enc "$line")&x=10&y=${Y}&color=pink&size=2"
    Y=$((Y + 22))
    LINES_DRAWN=$((LINES_DRAWN + 1))
    [ "$LINES_DRAWN" -ge 2 ] && break
  done < <(wrap_text "$CLEAN")

  # Gap between tasks
  Y=$((Y + 8))
done
