#!/usr/bin/env bash
# Time-aware greeting. For MOTD / terminal opens.
set -u
: "${PIXEL_BASE:?must be invoked via pixel wrapper}"

HOUR=$(date +%-H)
DOW=$(date +%u)  # 1=Mon, 7=Sun

if [ "$HOUR" -lt 5 ]; then
  MSG="up%20late"; ACCENT="ansiblue"
elif [ "$HOUR" -lt 12 ]; then
  MSG="morning"; ACCENT="orange"
elif [ "$HOUR" -lt 17 ]; then
  MSG="afternoon"; ACCENT="teal"
elif [ "$HOUR" -lt 21 ]; then
  MSG="evening"; ACCENT="hotpink"
else
  MSG="night"; ACCENT="ansiblue"
fi

# Sunday gets special weekend tag
[ "$DOW" = "7" ] && SUB="sunday" || SUB=""
[ "$DOW" = "6" ] && SUB="saturday"

px "clear"
# Big greeting
px "text?msg=${MSG}&x=50&y=80&color=pink&size=4"
# ej. underneath
px "text?msg=ej.&x=140&y=140&color=${ACCENT}&size=3"
# Weekend tag, small
[ -n "$SUB" ] && px "text?msg=${SUB}&x=130&y=200&color=mauve&size=1"

# Accent corner
px "circle?x=300&y=20&radius=6&color=${ACCENT}"
