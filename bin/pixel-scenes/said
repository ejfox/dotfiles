#!/usr/bin/env bash
# Show the last message claude-say spoke. Exits silently if message is stale.
# Wired into claude-say + safe in random rotation (only shows if fresh).
set -u
: "${PIXEL_BASE:?must be invoked via pixel wrapper}"

LAST="/tmp/claude-say-last.txt"
MAX_AGE=600  # 10 min — after this it's stale, skip

[ -s "$LAST" ] || exit 0
AGE=$(( $(date +%s) - $(stat -f %m "$LAST" 2>/dev/null || echo 0) ))
[ "$AGE" -gt "$MAX_AGE" ] && exit 0

MSG=$(cat "$LAST")
[ -z "$MSG" ] && exit 0

enc() { echo "$1" | sed 's/&/%26/g; s/?/%3F/g; s/+/%2B/g; s/ /%20/g; s/=/%3D/g; s/#/%23/g; s/'\''/%27/g; s/:/%3A/g; s/"/%22/g'; }

# Wrap to N-char lines for size 2 text (~26 chars per line at size 2)
wrap_to_lines() {
  local s="$1" max="$2"
  while [ -n "$s" ]; do
    # If remaining text is shorter than max, just print it
    if [ ${#s} -le "$max" ]; then
      echo "$s"
      break
    fi
    # Find last space within first $max chars
    local chunk="${s:0:$max}"
    local cut_at
    cut_at=$(echo "$chunk" | awk '{for(i=length;i>0;i--) if(substr($0,i,1)==" "){print i-1; exit}}')
    if [ -z "$cut_at" ] || [ "$cut_at" -eq 0 ]; then
      cut_at=$max
    fi
    echo "${s:0:$cut_at}"
    s="${s:$cut_at}"
    s="${s# }"
  done
}

px "clear"

# Voice name as the primary label (e.g., "maya" / "edward")
VOICE_FILE="/tmp/claude-say-last-voice.txt"
if [ -s "$VOICE_FILE" ]; then
  VOICE_NAME=$(cat "$VOICE_FILE")
  px "text?msg=${VOICE_NAME}&x=10&y=15&color=hotpink&size=1"
else
  px "text?msg=said&x=10&y=15&color=mauve&size=1"
fi

# Tmux window number — big teal digit in top-right corner
WIN_FILE="/tmp/claude-say-last-win.txt"
if [ -s "$WIN_FILE" ]; then
  WIN_NUM=$(cat "$WIN_FILE")
  if [ -n "$WIN_NUM" ]; then
    # tiny "win" label
    px "text?msg=win&x=255&y=8&color=mauve&size=1"
    # big number
    px "text?msg=${WIN_NUM}&x=280&y=4&color=teal&size=3"
  fi
fi

# Body — up to ~7 lines at size 2 (26 chars each), starting y=50, line height 24
LINE_Y=50
LINE_COUNT=0
while IFS= read -r line; do
  [ -z "$line" ] && continue
  px "text?msg=$(enc "$line")&x=15&y=${LINE_Y}&color=pink&size=2"
  LINE_Y=$((LINE_Y + 24))
  LINE_COUNT=$((LINE_COUNT + 1))
  [ "$LINE_COUNT" -ge 7 ] && break
done < <(wrap_to_lines "$MSG" 26)

# Bottom hairline
px "rect?x=10&y=225&w=300&h=1&color=dustrose"
