#!/usr/bin/env bash
# Generative drifting dot field. Pure ambient art, no info.
set -u
: "${PIXEL_BASE:?must be invoked via pixel wrapper}"

px "clear"

# Build a batch of ~40 dots in vulpes palette
COLORS=(
  "230,0,103"      # pink
  "110,237,247"    # teal
  "115,88,101"     # mauve
  "196,69,105"     # dustrose
  "168,123,181"    # ansiblue
  "94,196,196"     # ansicyan
)

JSON="["
FIRST=1
for i in $(seq 1 45); do
  X=$((RANDOM % 300 + 10))
  Y=$((RANDOM % 220 + 10))
  S=$(( (RANDOM % 6) + 2 ))
  C="${COLORS[$((RANDOM % ${#COLORS[@]}))]}"
  R=$(echo "$C" | cut -d, -f1)
  G=$(echo "$C" | cut -d, -f2)
  B=$(echo "$C" | cut -d, -f3)
  [ $FIRST -eq 0 ] && JSON="${JSON},"
  JSON="${JSON}{\"x\":${X},\"y\":${Y},\"r\":${R},\"g\":${G},\"b\":${B},\"s\":${S}}"
  FIRST=0
done
JSON="${JSON}]"

px_batch "$JSON"
