#!/usr/bin/env bash
# Pull weather from wttr.in. Show temp + condition icon-ish.
set -u
: "${PIXEL_BASE:?must be invoked via pixel wrapper}"

# wttr format: "+47°F Clear"
W=$(curl -s --connect-timeout 2 --max-time 4 "wttr.in/?format=%t+%C" 2>/dev/null)
[ -z "$W" ] && exit 0

TEMP=$(echo "$W" | awk '{print $1}' | tr -d '+°FfCc')
COND=$(echo "$W" | cut -d' ' -f2-)
[ -z "$TEMP" ] && exit 0

# Pick accent color by condition
COLOR="teal"
echo "$COND" | grep -iq "sun\|clear" && COLOR="orange"
echo "$COND" | grep -iq "rain\|drizz\|shower" && COLOR="ansiblue"
echo "$COND" | grep -iq "snow\|ice" && COLOR="cyan"
echo "$COND" | grep -iq "cloud\|overcast" && COLOR="mauve"
echo "$COND" | grep -iq "fog\|mist" && COLOR="ansicyan"
echo "$COND" | grep -iq "storm\|thunder" && COLOR="hotpink"

px "clear"

# Big temp
px "text?msg=${TEMP}F&x=80&y=70&color=pink&size=5"

# Condition word in accent color, lowercased
COND_LOWER=$(echo "$COND" | tr '[:upper:]' '[:lower:]' | tr -d ',;')
# Truncate to 20 chars, then URL-encode spaces
COND_TRUNC=$(echo "$COND_LOWER" | cut -c1-20 | sed 's/[[:space:]]*$//; s/ /%20/g')
px "text?msg=${COND_TRUNC}&x=80&y=160&color=${COLOR}&size=2"

# Decorative circle as 'sun/moon/cloud' indicator
px "circle?x=40&y=120&radius=14&color=${COLOR}"
