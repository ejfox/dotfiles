#!/usr/bin/env bash
# Currently reading book — random from Goodreads "currently-reading" shelf
set -u
: "${PIXEL_BASE:?must be invoked via pixel wrapper}"
command -v jq >/dev/null || exit 0

CACHE=$(~/.dotfiles/bin/pixel-scenes/.stats-fetch) || exit 0

# Pick random currently-reading book
COUNT=$(jq '.goodreads.currentlyReading | length' "$CACHE")
[ -z "$COUNT" ] || [ "$COUNT" -eq 0 ] && exit 0

IDX=$((RANDOM % COUNT))
TITLE=$(jq -r ".goodreads.currentlyReading[$IDX].title // \"\"" "$CACHE")
AUTHOR=$(jq -r ".goodreads.currentlyReading[$IDX].author // \"\"" "$CACHE")
PAGES=$(jq -r ".goodreads.currentlyReading[$IDX].numPages // 0" "$CACHE")
TOTAL_READ=$(jq -r '.goodreads.stats.totalRead // 0' "$CACHE")

[ -z "$TITLE" ] && exit 0

enc() { echo "$1" | sed 's/&/%26/g; s/?/%3F/g; s/+/%2B/g; s/ /%20/g; s/=/%3D/g; s/#/%23/g; s/'\''/%27/g; s/:/%3A/g'; }

# Wrap title to up to 3 lines of 22 chars each
wrap() {
  local s="$1" max="$2" out=()
  while [ -n "$s" ]; do
    out+=("$(echo "$s" | cut -c1-$max | sed 's/[[:space:]]*$//')")
    s=$(echo "$s" | cut -c$((max+1))- | sed 's/^[[:space:]]*//')
  done
  printf '%s\n' "${out[@]}"
}

px "clear"
# label
px "text?msg=reading&x=10&y=15&color=mauve&size=1"

# Title (up to 3 lines, size 2)
LINE_Y=55
while IFS= read -r line; do
  [ -z "$line" ] && continue
  px "text?msg=$(enc "$line")&x=15&y=${LINE_Y}&color=pink&size=2"
  LINE_Y=$((LINE_Y + 22))
  [ "$LINE_Y" -gt 130 ] && break
done < <(wrap "$TITLE" 22)

# Author below
AUTH_SHORT=$(echo "$AUTHOR" | cut -c1-30)
px "text?msg=$(enc "by ${AUTH_SHORT}")&x=15&y=160&color=teal&size=1"

# Pages + lifetime
[ "$PAGES" -gt 0 ] && px "text?msg=${PAGES}%20pages&x=15&y=180&color=mauve&size=1"
px "text?msg=$(enc "${TOTAL_READ} books read")&x=15&y=210&color=mauve&size=1"

# Right-side bookmark accent
px "rect?x=290&y=20&w=4&h=80&color=hotpink"
