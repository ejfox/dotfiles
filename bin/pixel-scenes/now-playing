#!/usr/bin/env bash
# Last/current track from last.fm via ejfox stats API
set -u
: "${PIXEL_BASE:?must be invoked via pixel wrapper}"
command -v jq >/dev/null || exit 0

CACHE=$(~/.dotfiles/bin/pixel-scenes/.stats-fetch) || exit 0

TRACK=$(jq -r '.lastfm.recentTracks.tracks[0].name // ""' "$CACHE")
ARTIST=$(jq -r '.lastfm.recentTracks.tracks[0].artist.name // ""' "$CACHE")
TOTAL=$(jq -r '.lastfm.userInfo.playcount // 0' "$CACHE")

[ -z "$TRACK" ] && exit 0

# URL encode helper
enc() { echo "$1" | sed 's/&/%26/g; s/?/%3F/g; s/+/%2B/g; s/ /%20/g; s/=/%3D/g; s/#/%23/g'; }

TRACK_SHORT=$(echo "$TRACK" | cut -c1-26)
ARTIST_SHORT=$(echo "$ARTIST" | cut -c1-26)

# Format total with commas
TOTAL_FMT=$(printf "%'d" "$TOTAL" 2>/dev/null || echo "$TOTAL")

px "clear"
# top-left label
px "text?msg=now%20playing&x=10&y=15&color=mauve&size=1"
# track in pink, fairly big
px "text?msg=$(enc "$TRACK_SHORT")&x=15&y=70&color=pink&size=3"
# artist in teal underneath
px "text?msg=$(enc "$ARTIST_SHORT")&x=15&y=120&color=teal&size=2"
# big lifetime scrobbles number bottom
px "text?msg=$(enc "${TOTAL_FMT} scrobbles")&x=10&y=210&color=mauve&size=1"
# small accent line
px "rect?x=10&y=95&w=160&h=1&color=dustrose"
