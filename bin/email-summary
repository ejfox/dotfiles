#!/bin/bash
# Smart email summary for startup script with AI insights

# Cache for 10 minutes
EMAIL_CACHE="/tmp/startup_cache/email_summary_cache.txt"
EMAIL_CACHE_MIN=10

# Check cache first
if [[ -f "$EMAIL_CACHE" ]] && [[ -z $(find "$EMAIL_CACHE" -mmin +$EMAIL_CACHE_MIN 2>/dev/null) ]]; then
  cat "$EMAIL_CACHE"
  exit 0
fi

# Check if maildir exists and has been synced
if [ ! -d "$HOME/Maildir/Inbox" ]; then
    echo "  📧 Email not synced yet" | tee "$EMAIL_CACHE"
    exit 0
fi

# Count unread emails in inbox.
# Maildir convention: new/ = unread (never seen), cur/ = seen (Seen flag in :2,S).
# Some sync setups flow everything through cur/ — count both sources to be robust.
unread_new=$(find "$HOME/Maildir/Inbox/new" -type f 2>/dev/null | wc -l | tr -d ' ')
unread_cur=$(find "$HOME/Maildir/Inbox/cur" -type f 2>/dev/null ! -name '*:2,*S*' | wc -l | tr -d ' ')
unread_count=$((unread_new + unread_cur))

# Sync staleness check — if last sync >12h ago, warn instead of lying
mbsyncstate="$HOME/Maildir/Inbox/.mbsyncstate"
if [ -f "$mbsyncstate" ]; then
    last_sync=$(stat -f %m "$mbsyncstate" 2>/dev/null)
    age_hours=$(( ($(date +%s) - last_sync) / 3600 ))
    if [ "$age_hours" -gt 12 ]; then
        echo "  ⚠ Inbox stale (last synced ${age_hours}h ago)" | tee "$EMAIL_CACHE"
        exit 0
    fi
fi

if [ "$unread_count" -eq 0 ]; then
    echo "  ✓ Inbox zero" | tee "$EMAIL_CACHE"
    exit 0
fi

# Sample MOST RECENT 10 emails for the LLM filter (Maildir filenames are
# timestamp-prefixed, so reverse-sort + head = newest first).
find "$HOME/Maildir/Inbox/new" "$HOME/Maildir/Inbox/cur" -type f 2>/dev/null | sort -r | head -10 | while read email; do
    subject=$(grep -i "^Subject:" "$email" 2>/dev/null | head -1 | sed 's/Subject: //')
    from=$(grep -i "^From:" "$email" 2>/dev/null | head -1 | sed 's/From: //' | sed 's/<.*>//' | tr -d '"')
    echo "From: $from | Subject: $subject"
done > /tmp/email_raw.txt

# Always show the count line first
output="  📧 $unread_count unread"

if [ -s /tmp/email_raw.txt ] && command -v llm >/dev/null 2>&1; then
    # BRUTAL FILTER: surface only genuinely urgent items. Ignore noise.
    result=$(cat /tmp/email_raw.txt | llm -m 4o-mini --no-log -s "You are a BRUTAL email filter. Only output emails that are:
- From actual humans who need a response
- Bills/payments actually due soon (not receipts)
- Meeting requests or calendar invites
- Urgent work requests

IGNORE and do not mention: newsletters, marketing, receipts, order confirmations, automated notifications, subscription notices, GitHub/deploy alerts, promotional emails.

If NOTHING passes the filter, output exactly: NONE

Otherwise output max 2 items, format: [!] description (10 words max)
No [>] or [-] - if it's not urgent, don't show it." 2>/dev/null | tr -cd '\11\12\15\40-\176')

    if [ -n "$result" ] && [ "$result" != "NONE" ]; then
        output="$output"$'\n'"$(echo "$result" | sed 's/^/  /')"
    fi
fi

echo "$output" | tee "$EMAIL_CACHE"
rm -f /tmp/email_raw.txt