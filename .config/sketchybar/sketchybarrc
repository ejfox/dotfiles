#!/bin/bash

# Use Monaspace Krypton everywhere
FONT="Monaspace Krypton"
NERD_FONT="Monaspace Krypton"

# Font-size spec (kept consistent across items):
#   PRIMARY   — 13pt, system anchors (clock, battery)
#   DATA      — 11pt, at-a-glance data widgets (next_event, demos, posts)
#   ICON      — 13pt, nerd-font glyphs
SIZE_PRIMARY=13.0
SIZE_DATA=11.0
SIZE_ICON=13.0

# Color spec:
MUTED=0xff888888    # passive UI (default widget label/icon)
DIM=0xff666666      # even quieter text

##### Bar Appearance #####
sketchybar --bar height=40 \
  blur_radius=0 \
  position=top \
  padding_left=12 \
  padding_right=12 \
  color=0xff000000 \
  corner_radius=0 \
  shadow=off \
  y_offset=-2 \
  margin=0

##### Defaults #####
sketchybar --default icon.font="$NERD_FONT:Regular:$SIZE_ICON" \
  icon.color=0xffffffff \
  label.font="$FONT:Regular:$SIZE_PRIMARY" \
  label.color=0xffffffff \
  background.drawing=off \
  padding_left=6 \
  padding_right=6 \
  label.padding_left=2 \
  label.padding_right=0 \
  icon.padding_left=0 \
  icon.padding_right=2 \
  y_offset=0 \
  updates=when_shown \
  icon.animation_duration=250 \
  label.animation_duration=250 \
  background.animation_duration=250

##### Plugin Directory #####
PLUGIN_DIR="$HOME/.config/sketchybar/plugins"

# ===== LEFT SIDE (left → right): talon, next_event, next_event.1..N =====

##### Talon Voice State ##### (pushed from ~/.talon/user/ejfox-overrides/sketchybar_bridge.py)
# No polling — the bridge fires `sketchybar --trigger talon_state MODE=<mode>` on every
# Talon context change. Hidden by default; plugin shows/styles on mode transitions.
sketchybar --add event talon_state
sketchybar --add item talon left \
  --set talon \
  updates=on \
  script="$PLUGIN_DIR/talon.sh" \
  drawing=off \
  icon.font="$FONT:Bold:$SIZE_DATA" \
  label.drawing=off \
  --subscribe talon talon_state

##### Hue-Key Toggle ##### (click to toggle keyboard → desk-light reactive typing)
sketchybar --add item huekey left \
  --set huekey \
  update_freq=10 \
  script="$PLUGIN_DIR/huekey.sh" \
  click_script="$PLUGIN_DIR/huekey.sh" \
  label.drawing=off \
  icon.font="$NERD_FONT:Regular:$SIZE_ICON"

##### Next Calendar Event #####
sketchybar --add item next_event left \
  --set next_event update_freq=60 \
  updates=on \
  script="$PLUGIN_DIR/next_event.sh" \
  icon.drawing=off \
  label.font="$FONT:Regular:$SIZE_DATA" \
  label.color=$DIM \
  click_script="open -a Calendar" \
  --subscribe next_event system_woke

# ===== RIGHT SIDE (left → right): demos, posts, battery, clock =====
# sketchybar renders right-side items in reverse add-order, so clock is added
# FIRST to become the rightmost anchor, and demos is added LAST to sit leftmost.

##### Time ##### (rightmost anchor, macOS convention)
sketchybar --add item clock right \
  --set clock update_freq=1 \
  label.width=58 \
  script="$PLUGIN_DIR/clock.sh"

##### Battery #####
sketchybar --add item battery right \
  --set battery update_freq=10 \
  script="$PLUGIN_DIR/battery.sh" \
  click_script="pmset -g batt"

##### Creative Nudges: 4-week dot matrices (hidden when Focus is on) #####
# posts (blog) sits right of demos (~/demos). Each dot = shipped at least one that week.
# Rightmost dot = this week (○ when empty). Icons: 󰕧 video camera, 󰎞 document.
sketchybar --add item posts right \
  --set posts update_freq=120 \
  icon="󰎞" \
  icon.color=$MUTED \
  label.font="$FONT:Regular:$SIZE_DATA" \
  script="$PLUGIN_DIR/posts.sh" \
  --subscribe posts system_woke

sketchybar --add item demos right \
  --set demos update_freq=120 \
  icon="󰕧" \
  icon.color=$MUTED \
  label.font="$FONT:Regular:$SIZE_DATA" \
  script="$PLUGIN_DIR/demos.sh" \
  --subscribe demos system_woke

##### Force initial update #####
sketchybar --update
sketchybar --trigger next_event
sketchybar --trigger demos
sketchybar --trigger posts
